rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function safeRole(role) {
      return role in ["CHEF", "RESTAURANT_ADMIN"] ? "PARTNER" :
        (role in ["CUSTOMER", "PARTNER", "DRIVER", "ADMIN"] ? role : "CUSTOMER");
    }

    function hasRole(role) {
      return hasUserProfile()
        && safeRole(currentUserData().role) == role;
    }

    function assignedRestaurantIds() {
      return currentUserData().managedRestaurantIds is list
        ? currentUserData().managedRestaurantIds
        : [];
    }

    function managesRestaurant(restaurantId) {
      return hasRole("ADMIN")
        || (
          hasRole("PARTNER")
          && restaurantId in assignedRestaurantIds()
        );
    }

    function ownerCanCreateProfile(userId) {
      return isOwner(userId)
        && request.resource.data.id == userId
        && request.resource.data.role == "CUSTOMER"
        && request.resource.data.managedRestaurantIds is list
        && request.resource.data.managedRestaurantIds.size() == 0
        && (
          !request.resource.data.keys().hasAny(["driverId"])
          || request.resource.data.driverId == ""
        );
    }

    function validRole(role) {
      return role in [
        "CUSTOMER",
        "PARTNER",
        "DRIVER",
        "ADMIN"
      ];
    }

    function adminCanWriteUserAccess() {
      return hasRole("ADMIN")
        && validRole(request.resource.data.role)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["role", "managedRestaurantIds", "driverId"]);
    }

    function driverIdUnchanged() {
      return (
          !resource.data.keys().hasAny(["driverId"])
          && !request.resource.data.keys().hasAny(["driverId"])
        )
        || (
          resource.data.keys().hasAny(["driverId"])
          && request.resource.data.keys().hasAny(["driverId"])
          && request.resource.data.driverId == resource.data.driverId
        );
    }

    function ownerCanUpdateProfile(userId) {
      return isOwner(userId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.managedRestaurantIds == resource.data.managedRestaurantIds
        && driverIdUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["fullName", "phone", "address"]);
    }

    function ownerCanBackfillSafeDefaults(userId) {
      return isOwner(userId)
        && request.resource.data.id == resource.data.id
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["email"])
          || (
            (!resource.data.keys().hasAny(["email"]) || resource.data.email == "")
            && request.resource.data.email is string
            && request.resource.data.email != ""
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"])
          || request.resource.data.role == "CUSTOMER"
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["managedRestaurantIds"])
          || (
            request.resource.data.managedRestaurantIds is list
            && request.resource.data.managedRestaurantIds.size() == 0
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["driverId"])
          || request.resource.data.driverId == ""
        )
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["email", "fullName", "role", "managedRestaurantIds", "driverId"]);
    }

    function validDriverData(data, driverId) {
      return data.id == driverId
        && data.fullName is string
        && data.phone is string
        && data.vehicleType is string
        && data.rating is number
        && data.rating >= 0
        && data.rating <= 5
        && (
          !data.keys().hasAny(["ratingCount"])
          || (
            data.ratingCount is int
            && data.ratingCount >= 0
          )
        )
        && data.isAvailable is bool;
    }

    function linkedDriverCanCreateOwnDriver(driverId) {
      return isLinkedDriver(driverId)
        && validDriverData(request.resource.data, driverId);
    }

    function restaurantCanUpdateSettings(restaurantId) {
      return managesRestaurant(restaurantId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["name", "cuisineType", "deliveryTime", "imageUrl", "address", "isOpen"]);
    }

    function customerCanUpdateRestaurantRating() {
      return hasRole("CUSTOMER")
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["rating", "ratingCount"])
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5
        && request.resource.data.ratingCount is int
        && request.resource.data.ratingCount == (
          resource.data.keys().hasAny(["ratingCount"]) && resource.data.ratingCount is int
            ? resource.data.ratingCount + 1
            : 1
        );
    }

    function customerCanUpdateDriverRating() {
      return hasRole("CUSTOMER")
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["rating", "ratingCount"])
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5
        && request.resource.data.ratingCount is int
        && request.resource.data.ratingCount == (
          resource.data.keys().hasAny(["ratingCount"]) && resource.data.ratingCount is int
            ? resource.data.ratingCount + 1
            : 1
        );
    }

    function validRestaurantReview(data) {
      return hasRole("CUSTOMER")
        && data.orderId is string
        && data.orderId != ""
        && data.restaurantId is string
        && data.restaurantId != ""
        && data.userId == request.auth.uid
        && data.customerId == request.auth.uid
        && data.customerName is string
        && data.rating is number
        && data.rating >= 1
        && data.rating <= 5
        && data.comment is string
        && exists(/databases/$(database)/documents/orders/$(data.orderId))
        && get(/databases/$(database)/documents/orders/$(data.orderId)).data.status == "DELIVERED"
        && orderBelongsToCurrentUser(get(/databases/$(database)/documents/orders/$(data.orderId)).data)
        && get(/databases/$(database)/documents/orders/$(data.orderId)).data.restaurantId == data.restaurantId;
    }

    function validNotificationData(data) {
      return isSignedIn()
        && data.id is string
        && data.title is string
        && data.title != ""
        && data.message is string
        && data.message != ""
        && data.type is string
        && data.isRead is bool
        && data.createdAt is number
        && data.userId is string
        && data.roleTarget is string
        && (
          data.userId == request.auth.uid
          || data.roleTarget in ["CUSTOMER", "PARTNER", "DRIVER", "ADMIN"]
          || hasRole("ADMIN")
        );
    }

    function canReadNotification(data) {
      return isSignedIn()
        && (
          data.userId == request.auth.uid
          || data.roleTarget == safeRole(currentUserData().role)
          || hasRole("ADMIN")
        );
    }

    function canMarkOwnNotificationRead() {
      return resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"])
        && request.resource.data.isRead == true;
    }

    function validMenuItemData(data) {
      return data.restaurantId is string
        && data.restaurantId != ""
        && data.name is string
        && data.name != ""
        && data.description is string
        && data.description != ""
        && data.category is string
        && data.category != ""
        && data.price is number
        && data.price > 0;
    }

    function customerCanCreateOrder() {
      return hasRole("CUSTOMER")
        && request.resource.data.userId == request.auth.uid
        && (
          !request.resource.data.keys().hasAny(["customerId"])
          || request.resource.data.customerId == request.auth.uid
        )
        && request.resource.data.status == "PENDING"
        && request.resource.data.restaurantId is string
        && request.resource.data.restaurantId != ""
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.totalPrice is number
        && request.resource.data.totalPrice > 0
        && request.resource.data.pickupCode is string
        && request.resource.data.pickupCode != "";
    }

    function orderBelongsToCurrentUser(data) {
      return isSignedIn()
        && (
          (
            data.keys().hasAny(["userId"])
            && data.userId == request.auth.uid
          )
          || (
            (!data.keys().hasAny(["userId"]) || data.userId == "")
            && data.keys().hasAny(["customerId"])
            && data.customerId == request.auth.uid
          )
        );
    }

    function onlyStatusChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]);
    }

    function linkedDriverId() {
      return currentUserData().driverId is string ? currentUserData().driverId : "";
    }

    function isLinkedDriver(driverId) {
      return hasRole("DRIVER")
        && (
          linkedDriverId() == driverId
          || (
            linkedDriverId() == ""
            && driverId == request.auth.uid
          )
        );
    }

    function isReadyForPickupStatus(status) {
      return status in [
        "READY_FOR_PICKUP",
        "Ready for pickup",
        "ready_for_pickup",
        "READY_FOR_PICK_UP",
        "READY_FOR_DELIVERY",
        "READY"
      ];
    }

    function driverIdentityMatches(driverId) {
      return hasRole("DRIVER")
        && (
          driverId == linkedDriverId()
          || driverId == request.auth.uid
        );
    }

    function dataDriverId(data) {
      return (data.keys().hasAny(["driverId"]) && data.driverId is string) ? data.driverId : "";
    }

    function dataDriverUserId(data) {
      return (data.keys().hasAny(["driverUserId"]) && data.driverUserId is string) ? data.driverUserId : "";
    }

    function dataDriverProfileId(data) {
      return (data.keys().hasAny(["driverProfileId"]) && data.driverProfileId is string) ? data.driverProfileId : "";
    }

    function driverReviewMatchesOrder(orderData, reviewData) {
      return (
          dataDriverProfileId(orderData) != ""
          && dataDriverProfileId(orderData) == reviewData.driverId
        )
        || (
          dataDriverId(orderData) != ""
          && dataDriverId(orderData) == reviewData.driverId
        )
        || (
          reviewData.driverUserId != ""
          && dataDriverUserId(orderData) == reviewData.driverUserId
        );
    }

    function validDriverReview(data, reviewId) {
      return hasRole("CUSTOMER")
        && data.id == reviewId
        && data.orderId is string
        && data.orderId != ""
        && data.driverId is string
        && data.driverId != ""
        && data.driverUserId is string
        && data.customerId == request.auth.uid
        && data.customerName is string
        && data.rating is number
        && data.rating >= 1
        && data.rating <= 5
        && data.comment is string
        && data.createdAt is number
        && exists(/databases/$(database)/documents/drivers/$(data.driverId))
        && exists(/databases/$(database)/documents/orders/$(data.orderId))
        && get(/databases/$(database)/documents/orders/$(data.orderId)).data.status == "DELIVERED"
        && orderBelongsToCurrentUser(get(/databases/$(database)/documents/orders/$(data.orderId)).data)
        && driverReviewMatchesOrder(get(/databases/$(database)/documents/orders/$(data.orderId)).data, data);
    }

    function orderAssignedToCurrentDriver(data) {
      return driverIdentityMatches(dataDriverId(data))
        || driverIdentityMatches(dataDriverUserId(data))
        || driverIdentityMatches(dataDriverProfileId(data));
    }

    function orderHasNoAssignedDriver(data) {
      return dataDriverId(data) == ""
        && dataDriverUserId(data) == ""
        && dataDriverProfileId(data) == "";
    }

    function requestedDriverIdIsCurrentDriver() {
      return (
          request.resource.data.driverProfileId == linkedDriverId()
          && request.resource.data.driverId == linkedDriverId()
          && request.resource.data.driverUserId == request.auth.uid
        )
        || (
          linkedDriverId() == ""
          && request.resource.data.driverId == request.auth.uid
          && request.resource.data.driverUserId == request.auth.uid
          && request.resource.data.driverProfileId == request.auth.uid
        );
    }

    function driverCanUpdateAvailability(driverId) {
      return isLinkedDriver(driverId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isAvailable"]);
    }

    function driverCanReadOrder() {
      return hasRole("DRIVER")
        && (
          (
            isReadyForPickupStatus(resource.data.status)
            && (
              orderHasNoAssignedDriver(resource.data)
              || orderAssignedToCurrentDriver(resource.data)
            )
          )
          || orderAssignedToCurrentDriver(resource.data)
        );
    }

    function orderDriverIsOpenOrMine() {
      return orderHasNoAssignedDriver(resource.data)
        || orderAssignedToCurrentDriver(resource.data);
    }

    function driverCanUpdateOrder() {
      return hasRole("DRIVER")
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                "status",
                "driverId",
                "driverUserId",
                "driverProfileId",
                "pickupCodeValidation",
                "pickupCodeValidatedAt",
                "pickedUpAt",
                "updatedAt"
              ])
            && request.resource.data.status == "PICKED_UP"
            && isReadyForPickupStatus(resource.data.status)
            && orderDriverIsOpenOrMine()
            && requestedDriverIdIsCurrentDriver()
            && request.resource.data.pickupCode == resource.data.pickupCode
            && request.resource.data.pickupCodeValidation == resource.data.pickupCode
            && request.resource.data.pickupCodeValidatedAt is number
            && request.resource.data.pickedUpAt is number
            && request.resource.data.updatedAt is number
          )
          || (
            orderAssignedToCurrentDriver(resource.data)
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["status", "driverId", "driverUserId", "driverProfileId", "updatedAt"])
            && requestedDriverIdIsCurrentDriver()
            && request.resource.data.status == "ON_THE_WAY"
            && resource.data.status == "PICKED_UP"
            && request.resource.data.updatedAt is number
          )
          || (
            orderAssignedToCurrentDriver(resource.data)
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["status", "driverId", "driverUserId", "driverProfileId", "updatedAt", "deliveredAt"])
            && requestedDriverIdIsCurrentDriver()
            && request.resource.data.status == "DELIVERED"
            && resource.data.status == "ON_THE_WAY"
            && request.resource.data.updatedAt is number
            && request.resource.data.deliveredAt is number
          )
        );
    }

    function managerCanUpdatePreparationOrder() {
      return managesRestaurant(resource.data.restaurantId)
        && onlyStatusChanged()
        && (
          (
            request.resource.data.status == "ACCEPTED"
            && resource.data.status == "PENDING"
          )
          || (
            request.resource.data.status == "PREPARING"
            && resource.data.status == "ACCEPTED"
          )
          || (
            request.resource.data.status == "READY_FOR_PICKUP"
            && resource.data.status == "PREPARING"
          )
        );
    }

    match /users/{userId} {
      allow create: if ownerCanCreateProfile(userId) || hasRole("ADMIN");
      allow read: if isOwner(userId) || hasRole("ADMIN");
      allow update: if ownerCanUpdateProfile(userId) || ownerCanBackfillSafeDefaults(userId) || adminCanWriteUserAccess();
      allow delete: if hasRole("ADMIN");
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create, delete: if hasRole("ADMIN");
      allow update: if restaurantCanUpdateSettings(restaurantId) || customerCanUpdateRestaurantRating();
    }

    match /restaurantReviews/{reviewId} {
      allow read: if true;
      allow create: if validRestaurantReview(request.resource.data);
      allow update, delete: if false;
    }

    match /driverReviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if validDriverReview(request.resource.data, reviewId);
      allow update, delete: if false;
    }

    match /menuItems/{menuItemId} {
      allow read: if true;
      allow create: if validMenuItemData(request.resource.data)
        && managesRestaurant(request.resource.data.restaurantId);
      allow update: if managesRestaurant(resource.data.restaurantId)
        && request.resource.data.restaurantId == resource.data.restaurantId
        && validMenuItemData(request.resource.data);
      allow delete: if managesRestaurant(resource.data.restaurantId);
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow create: if hasRole("ADMIN") || linkedDriverCanCreateOwnDriver(driverId);
      allow delete: if hasRole("ADMIN");
      allow update: if hasRole("ADMIN") || driverCanUpdateAvailability(driverId) || customerCanUpdateDriverRating();
    }

    match /workerInvitations/{invitationId} {
      allow read, create, update, delete: if hasRole("ADMIN");
    }

    match /notifications/{notificationId} {
      allow read: if canReadNotification(resource.data);
      allow create: if validNotificationData(request.resource.data);
      allow update: if canMarkOwnNotificationRead() || hasRole("ADMIN");
      allow delete: if hasRole("ADMIN");
    }

    match /orders/{orderId} {
      allow create: if customerCanCreateOrder();

      allow read: if isSignedIn()
        && (orderBelongsToCurrentUser(resource.data)
          || managesRestaurant(resource.data.restaurantId)
          || driverCanReadOrder());

      allow update: if isSignedIn()
        && (
          (
            orderBelongsToCurrentUser(resource.data)
            && onlyStatusChanged()
            && request.resource.data.status == "CANCELLED"
            && resource.data.status in ["PENDING", "ACCEPTED"]
          )
          || managerCanUpdatePreparationOrder()
          || driverCanUpdateOrder()
        );

      allow delete: if hasRole("ADMIN");
    }
  }
}
