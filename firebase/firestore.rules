rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return hasUserProfile()
        && currentUserData().role == role;
    }

    function assignedRestaurantIds() {
      return currentUserData().managedRestaurantIds is list
        ? currentUserData().managedRestaurantIds
        : [];
    }

    function managesRestaurant(restaurantId) {
      return hasRole("ADMIN")
        || (
          (hasRole("PARTNER") || hasRole("RESTAURANT_ADMIN"))
          && restaurantId in assignedRestaurantIds()
        );
    }

    function worksInKitchen(restaurantId) {
      return hasRole("CHEF") && restaurantId in assignedRestaurantIds();
    }

    function ownerCanCreateProfile(userId) {
      return isOwner(userId)
        && request.resource.data.id == userId
        && request.resource.data.role == "CUSTOMER"
        && request.resource.data.managedRestaurantIds is list
        && request.resource.data.managedRestaurantIds.size() == 0
        && (
          !request.resource.data.keys().hasAny(["driverId"])
          || request.resource.data.driverId == ""
        );
    }

    function validRole(role) {
      return role in [
        "CUSTOMER",
        "PARTNER",
        "RESTAURANT_ADMIN",
        "CHEF",
        "DRIVER",
        "ADMIN"
      ];
    }

    function adminCanWriteUserAccess() {
      return hasRole("ADMIN")
        && validRole(request.resource.data.role)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["role", "managedRestaurantIds", "driverId"]);
    }

    function driverIdUnchanged() {
      return (
          !resource.data.keys().hasAny(["driverId"])
          && !request.resource.data.keys().hasAny(["driverId"])
        )
        || (
          resource.data.keys().hasAny(["driverId"])
          && request.resource.data.keys().hasAny(["driverId"])
          && request.resource.data.driverId == resource.data.driverId
        );
    }

    function ownerCanUpdateProfile(userId) {
      return isOwner(userId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.managedRestaurantIds == resource.data.managedRestaurantIds
        && driverIdUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["fullName", "phone", "address"]);
    }

    function ownerCanBackfillSafeDefaults(userId) {
      return isOwner(userId)
        && request.resource.data.id == resource.data.id
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["email"])
          || (
            (!resource.data.keys().hasAny(["email"]) || resource.data.email == "")
            && request.resource.data.email is string
            && request.resource.data.email != ""
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"])
          || request.resource.data.role == "CUSTOMER"
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["managedRestaurantIds"])
          || (
            request.resource.data.managedRestaurantIds is list
            && request.resource.data.managedRestaurantIds.size() == 0
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["driverId"])
          || request.resource.data.driverId == ""
        )
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["email", "fullName", "role", "managedRestaurantIds", "driverId"]);
    }

    function validDriverData(data, driverId) {
      return data.id == driverId
        && data.fullName is string
        && data.phone is string
        && data.vehicleType is string
        && data.rating is number
        && data.rating >= 0
        && data.rating <= 5
        && data.isAvailable is bool;
    }

    function linkedDriverCanCreateOwnDriver(driverId) {
      return isLinkedDriver(driverId)
        && validDriverData(request.resource.data, driverId);
    }

    function restaurantCanUpdateSettings(restaurantId) {
      return managesRestaurant(restaurantId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["name", "cuisineType", "deliveryTime", "imageUrl", "isOpen"]);
    }

    function validMenuItemData(data) {
      return data.restaurantId is string
        && data.restaurantId != ""
        && data.name is string
        && data.name != ""
        && data.description is string
        && data.description != ""
        && data.category is string
        && data.category != ""
        && data.price is number
        && data.price > 0;
    }

    function customerCanCreateOrder() {
      return hasRole("CUSTOMER")
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "PENDING"
        && request.resource.data.restaurantId is string
        && request.resource.data.restaurantId != ""
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.totalPrice is number
        && request.resource.data.totalPrice > 0
        && request.resource.data.pickupCode is string
        && request.resource.data.pickupCode != "";
    }

    function onlyStatusChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]);
    }

    function linkedDriverId() {
      return currentUserData().driverId is string ? currentUserData().driverId : "";
    }

    function isLinkedDriver(driverId) {
      return hasRole("DRIVER") && linkedDriverId() == driverId;
    }

    function driverCanUpdateAvailability(driverId) {
      return isLinkedDriver(driverId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isAvailable"]);
    }

    function driverCanReadOrder() {
      return hasRole("DRIVER")
        && (
          resource.data.status == "READY_FOR_PICKUP"
          || resource.data.driverId == linkedDriverId()
        );
    }

    function orderDriverIsOpenOrMine() {
      return !resource.data.keys().hasAny(["driverId"])
        || resource.data.driverId == ""
        || resource.data.driverId == linkedDriverId();
    }

    function driverCanUpdateOrder() {
      return hasRole("DRIVER")
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["status", "driverId", "pickupCodeValidation", "pickupCodeValidatedAt"])
            && request.resource.data.status == "ON_THE_WAY"
            && resource.data.status == "READY_FOR_PICKUP"
            && orderDriverIsOpenOrMine()
            && request.resource.data.driverId == linkedDriverId()
            && request.resource.data.pickupCode == resource.data.pickupCode
            && request.resource.data.pickupCodeValidation == resource.data.pickupCode
            && request.resource.data.pickupCodeValidatedAt is number
          )
          || (
            resource.data.driverId == linkedDriverId()
            && onlyStatusChanged()
            && request.resource.data.status == "DELIVERED"
            && resource.data.status == "ON_THE_WAY"
          )
        );
    }

    function kitchenCanUpdateOrder() {
      return worksInKitchen(resource.data.restaurantId)
        && onlyStatusChanged()
        && (
          (
            request.resource.data.status == "PREPARING"
            && resource.data.status == "CONFIRMED"
          )
          || (
            request.resource.data.status == "READY_FOR_PICKUP"
            && resource.data.status == "PREPARING"
          )
        );
    }

    function managerCanConfirmOrder() {
      return managesRestaurant(resource.data.restaurantId)
        && onlyStatusChanged()
        && request.resource.data.status == "CONFIRMED"
        && resource.data.status == "PENDING";
    }

    match /users/{userId} {
      allow create: if ownerCanCreateProfile(userId) || hasRole("ADMIN");
      allow read: if isOwner(userId) || hasRole("ADMIN");
      allow update: if ownerCanUpdateProfile(userId) || ownerCanBackfillSafeDefaults(userId) || adminCanWriteUserAccess();
      allow delete: if hasRole("ADMIN");
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create, delete: if hasRole("ADMIN");
      allow update: if restaurantCanUpdateSettings(restaurantId);
    }

    match /menuItems/{menuItemId} {
      allow read: if true;
      allow create: if validMenuItemData(request.resource.data)
        && managesRestaurant(request.resource.data.restaurantId);
      allow update: if managesRestaurant(resource.data.restaurantId)
        && request.resource.data.restaurantId == resource.data.restaurantId
        && validMenuItemData(request.resource.data);
      allow delete: if managesRestaurant(resource.data.restaurantId);
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow create: if hasRole("ADMIN") || linkedDriverCanCreateOwnDriver(driverId);
      allow delete: if hasRole("ADMIN");
      allow update: if hasRole("ADMIN") || driverCanUpdateAvailability(driverId);
    }

    match /orders/{orderId} {
      allow create: if customerCanCreateOrder();

      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
          || managesRestaurant(resource.data.restaurantId)
          || worksInKitchen(resource.data.restaurantId)
          || driverCanReadOrder());

      allow update: if isSignedIn()
        && (
          (
            resource.data.userId == request.auth.uid
            && onlyStatusChanged()
            && request.resource.data.status == "CANCELLED"
            && resource.data.status in ["PENDING", "CONFIRMED"]
          )
          || managerCanConfirmOrder()
          || kitchenCanUpdateOrder()
          || driverCanUpdateOrder()
        );

      allow delete: if hasRole("ADMIN");
    }
  }
}
